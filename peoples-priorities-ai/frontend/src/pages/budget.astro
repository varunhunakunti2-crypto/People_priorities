---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar';
import BudgetSimulatorApp from '../components/BudgetSimulatorApp';
---

<Layout title="Budget Simulator - People's Priorities">
  <div id="app-wrapper" class="min-h-screen bg-[#FAFAFA] opacity-0 transition-opacity duration-150">
    <NavBar client:load />
    
    <div class="w-full max-w-6xl mx-auto site-pad">
      <main class="py-12 w-full">
        <div class="mb-8 text-center flex flex-col items-center">
          <h1 class="text-[32px] font-bold text-[#111111] leading-tight mb-2">
            Budget Simulator
          </h1>
          <p class="text-[14px] text-[#666666]">
            Generate an optimized MPLADS sanction list within your available budget
          </p>
        </div>
        
        <hr class="border-t border-[#E6E6E6] mb-8 w-full" />
        
        <BudgetSimulatorApp client:load />
      </main>
    </div>
  </div>
</Layout>

<script>
  import { isAuthenticated } from '../lib/auth';

  // Client-side authentication guard
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  } else {
    // Show app layout once verified
    const wrapper = document.getElementById('app-wrapper');
    if (wrapper) {
      wrapper.classList.remove('opacity-0');
    }
  }
</script>
