---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="flex h-screen flex-col items-center justify-center bg-[#fafafa] text-[#171717]">
    <h1 class="text-6xl font-bold tracking-tight">404</h1>
    <p class="mt-4 text-lg text-[#4d4d4d]">Page not found</p>
    <a href="/" class="mt-6 rounded-md bg-[#171717] px-4 py-2 text-sm font-medium text-white transition hover:bg-[#333333]">
      Go back home
    </a>
  </div>
</Layout>
